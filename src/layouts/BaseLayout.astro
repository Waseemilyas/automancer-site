---
import SEO from '../components/SEO.astro';
import JsonLd from '../components/JsonLd.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  image?: string;
  ogType?: 'website' | 'article';
}

const { title, description, image, ogType = 'website' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#000000" />
    <SEO title={`${title} | Automancer`} description={description} image={image} type={ogType} />

    <link rel="icon" type="image/png" sizes="32x32" href="/assets/images/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/assets/images/favicon-16.png" />
    <link rel="icon" href="/assets/images/logo.svg" type="image/svg+xml" />

    <!-- Fonts: two display voices (Syne + JetBrains Mono machine voice),
         Space Grotesk for UI/body, Outfit for long-form reading. Weights
         trimmed to what the design actually uses; display=swap avoids FOIT.
         Self-hosted from our own origin (see public/assets/css/fonts.css) —
         no request ever leaves the visitor's browser to a third-party font
         host, so no visitor IP is shared with Google. -->
    <link rel="preload" href="/assets/fonts/space-grotesk-400-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/assets/fonts/syne-800-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="stylesheet" href="/assets/css/fonts.css" />

    <!-- Business-wide structured data, on every page. -->
    <JsonLd type="LocalBusiness" />

    <!-- Page-specific extra <head> content: Article JSON-LD on field notes,
         the Turnstile script on the contact page, etc. -->
    <slot name="head" />

    <!-- UTM capture: whatever page a campaign lands on, persist utm_* from
         the URL for the visit so the contact form can attribute the lead
         (src/pages/contact.astro includes them in the /api/lead payload).
         First touch wins; sessionStorage only — nothing leaves the browser
         until the visitor actually submits the form. -->
    <script is:inline>
      (function () {
        try {
          var params = new URLSearchParams(location.search);
          var source = params.get('utm_source') || '';
          var medium = params.get('utm_medium') || '';
          var campaign = params.get('utm_campaign') || '';
          if ((source || medium || campaign) && !sessionStorage.getItem('aut-utm')) {
            sessionStorage.setItem(
              'aut-utm',
              JSON.stringify({ utmSource: source, utmMedium: medium, utmCampaign: campaign })
            );
          }
        } catch (e) {
          /* storage unavailable (private mode etc.) — attribution is best-effort */
        }
      })();
    </script>
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Nav />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <script is:inline src="/assets/js/main.js" defer></script>
  </body>
</html>
