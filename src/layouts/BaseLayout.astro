---
import SEO from '../components/SEO.astro';
import JsonLd from '../components/JsonLd.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  image?: string;
  ogType?: 'website' | 'article';
}

const { title, description, image, ogType = 'website' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#000000" />
    <SEO title={`${title} | Automancer`} description={description} image={image} type={ogType} />

    <link rel="icon" type="image/png" sizes="32x32" href="/assets/images/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/assets/images/favicon-16.png" />
    <link rel="icon" href="/assets/images/logo.svg" type="image/svg+xml" />

    <!-- Fonts: two display voices (Syne + JetBrains Mono machine voice),
         Space Grotesk for UI/body, Outfit for long-form reading. Weights
         trimmed to what the design actually uses; display=swap avoids FOIT.
         Self-hosted from our own origin (see public/assets/css/fonts.css) —
         no request ever leaves the visitor's browser to a third-party font
         host, so no visitor IP is shared with Google. -->
    <link rel="preload" href="/assets/fonts/space-grotesk-400-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/assets/fonts/syne-800-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="stylesheet" href="/assets/css/fonts.css" />

    <!-- Business-wide structured data, on every page. -->
    <JsonLd type="LocalBusiness" />

    <!-- Page-specific extra <head> content: Article JSON-LD on field notes,
         the Turnstile script on the contact page, etc. -->
    <slot name="head" />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Nav />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <script is:inline src="/assets/js/main.js" defer></script>
  </body>
</html>
