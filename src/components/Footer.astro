---
import { business } from '../data/business';
import ProofStrip from './ProofStrip.astro';

const year = new Date().getFullYear();
---

<footer class="footer" role="contentinfo">
  <ProofStrip />

  <div class="wrap">
    <div class="footer__top">
      <div>
        <div class="footer__brand">
          <img src="/assets/images/logo.svg" alt="" class="footer__mark" width="34" height="39" />
          <span class="footer__word">Automancer</span>
        </div>
        <p class="footer__addr">
          {business.legalName} · Company No. {business.companyNumber}<br />
          {business.address.streetAddress}, {business.address.addressLocality}, {business.address.postalCode}<br />
          <a href={`mailto:${business.email}`} class="tlink">{business.email}</a>
        </p>
        <p class="footer__addr" style="margin-top:var(--sp-5)">
          It's not magic. It's very good engineering.
        </p>
      </div>

      <div class="footer__col">
        <h4>Navigate</h4>
        <nav aria-label="Footer">
          <a href="/">Home</a>
          <a href="/services">Services &amp; pricing</a>
          <a href="/work">Work</a>
          <a href="/field-notes">Field notes</a>
          <a href="/about">About</a>
          <a href="/contact">Contact</a>
        </nav>
      </div>

      <div class="footer__col">
        <h4>Start here</h4>
        <nav aria-label="Get in touch">
          <a href="/contact">Book an Audit — from £450</a>
          <a href="/contact">Tell us what's eating your week</a>
          <a href={`mailto:${business.email}`}>{business.email}</a>
        </nav>
      </div>
    </div>

    <div class="footer__bottom">
      <span>&copy; {year} {business.legalName}. Based in Bingley, serving the UK.</span>
      <span class="footer__legal">
        <a href="/privacy">Privacy</a>
        <a href="/terms">Terms</a>
        <a href="/llms.txt">llms.txt</a>
      </span>
    </div>
  </div>
</footer>
