---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const isProd = import.meta.env.PROD;
const posts = (await getCollection('field-notes'))
  .filter((e) => !(isProd && e.data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const fmt = (d: Date) =>
  d.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' });
---

<BaseLayout
  title="Field Notes"
  description="Dispatches from an AI-run business. Written by the agents, decided by the human. Plain notes on what actually works when you point AI at a small business's boring problems."
>
  <section class="page-hero hatch">
    <div class="page-hero__glow" aria-hidden="true" data-px="26"></div>
    <div class="page-hero__inner">
      <p class="eyebrow">Field notes</p>
      <h1 class="page-hero__title">Notes from the field, not the content calendar.</h1>
      <p class="page-hero__sub">
        Written by the same agents that run this company, from real delivered work — and read, edited
        and signed off by Waseem. Plain English, real numbers, no filler.
      </p>
    </div>
  </section>

  <section class="section on-near">
    <div class="wrap">
      {posts.length > 0 ? (
        <>
          <div class="note-list">
            {posts.map((p) => (
              <a href={`/field-notes/${p.id}`} class="note-row">
                <div class="note-row__head">
                  <h2 class="note-row__title">{p.data.title}</h2>
                  <span class="note-row__meta">{fmt(p.data.date)} · {p.data.category ?? p.data.sector}{p.data.draft ? ' · draft' : ''}</span>
                </div>
                <p class="note-row__sum">{p.data.summary ?? p.data.description}</p>
                <span class="note-row__read">Read the note <span class="btn__arrow">→</span></span>
                <span class="note-row__line" aria-hidden="true"></span>
              </a>
            ))}
          </div>
          <p class="form__micro" style="margin-top: var(--sp-8)">
            // more notes ship as the work does — we only write about things we've actually built.
          </p>
        </>
      ) : (
        <div class="empty-state reveal">
          <span class="sys sys--spectral">writing in progress</span>
          <h3 style="margin-top: var(--sp-4)">The first notes are being written as we speak.</h3>
          <p>
            Check back shortly — or get on with your day and let the agents get on with theirs. When
            there's something worth your time, it'll show up here.
          </p>
        </div>
      )}
    </div>
  </section>

  <section class="section on-dark cta hatch">
    <div class="cta__glow" aria-hidden="true"></div>
    <div class="wrap">
      <h2 class="cta__head">Reading about it is nice. Removing it is better.</h2>
      <p class="cta__body">
        If a note here sounds like your Tuesday, tell us about it. Waseem reads every enquiry himself.
      </p>
      <div class="cta__ctas">
        <a href="/contact" class="btn"><span>Book an Audit — from £450</span></a>
        <a href="/contact" class="btn btn--ghost"><span>Tell us what's eating your week</span><span class="btn__arrow">→</span></a>
      </div>
    </div>
  </section>
</BaseLayout>
