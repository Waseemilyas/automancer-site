---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="AI &amp; Workflow Automation for Small Businesses"
  description="Practical AI and workflow automation for UK small businesses. Cut admin, reduce errors, and improve operations with Automancer."
>
  <section class="hero">
    <div class="hero__inner">
      <h1 class="hero__headline">
        AI and workflow automation for small businesses that want less admin and more momentum.
      </h1>
      <p class="hero__sub">
        Automancer helps you remove repetitive work, cut avoidable errors, and speed up
        operations with practical automation your team can actually use.
      </p>
      <div class="hero__ctas">
        <a href="/contact" class="btn btn--primary"><span>Book a consultation</span></a>
        <a href="/services" class="btn btn--secondary"><span>See services</span></a>
      </div>
    </div>
  </section>

  <section class="section section--light">
    <div class="container">
      <span class="label">Services</span>
      <h2>Practical automation, real outcomes.</h2>
      <div class="services-grid">
        <a href="/services" class="service-card">
          <h3 class="service-card__name">Automation Opportunity Audit</h3>
          <p class="service-card__desc">Get a clear roadmap of what to automate first.</p>
        </a>
        <a href="/services" class="service-card">
          <h3 class="service-card__name">Workflow Implementation Sprint</h3>
          <p class="service-card__desc">Build and launch 1&ndash;3 high-impact workflows.</p>
        </a>
        <a href="/services" class="service-card">
          <h3 class="service-card__name">System/Agent Build</h3>
          <p class="service-card__desc">From simple assistants to full AI employees powered by your organisational knowledge.</p>
        </a>
        <a href="/services" class="service-card">
          <h3 class="service-card__name">AI Ops Partner</h3>
          <p class="service-card__desc">Ongoing optimisation and support as your automation footprint grows.</p>
        </a>
      </div>
    </div>
  </section>

  <section class="section section--dark">
    <div class="container">
      <span class="label">Why Automancer</span>
      <h2>Systems that run smoothly.</h2>
      <p class="text-lg">Most small businesses don't need hype. They need systems that run smoothly.</p>
      <p class="text-lg">We help you spot what's slowing the business down, then design and implement practical automation around your real workflows.</p>
    </div>
  </section>

  <section class="section section--off-white">
    <div class="container">
      <span class="label">Who we help</span>
      <h2>Built for businesses like yours.</h2>
      <ul class="check-list">
        <li>Founder-led and growing teams</li>
        <li>Service businesses with repeat admin/process bottlenecks</li>
        <li>Businesses that want measurable efficiency gains</li>
      </ul>
    </div>
  </section>

  <section class="section section--dark">
    <div class="container">
      <span class="label">Where we work</span>
      <p class="text-lg">We support businesses UK-wide remotely, with a practical local focus on Bradford, Leeds and Manchester.</p>
    </div>
  </section>

  <section class="section section--dark">
    <div class="container">
      <span class="label">How we work</span>
      <h2>From conversation to operation.</h2>
      <ol class="steps">
        <li class="step">Consultation and workflow diagnosis</li>
        <li class="step">Audit or implementation plan</li>
        <li class="step">Build, test and handover</li>
        <li class="step">Optimisation as your business grows</li>
      </ol>
    </div>
  </section>

  <section class="section section--light">
    <div class="container container--narrow">
      <span class="label">Trust &amp; boundaries</span>
      <p class="text-sm">
        We focus on practical automation for everyday business operations. By default, we do
        not take high-risk engagements involving patient-data-heavy systems or highly
        confidential government/military workflows unless explicitly agreed.
      </p>
    </div>
  </section>

  <section class="section section--dark cta-block">
    <div class="container">
      <h2 class="cta-block__heading">Ready to remove bottlenecks and free up your team's time?</h2>
      <a href="/contact" class="btn btn--primary"><span>Book a consultation</span></a>
    </div>
  </section>
</BaseLayout>
