---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const isProd = import.meta.env.PROD;
const studies = (await getCollection('case-studies'))
  .filter((e) => !(isProd && e.data.draft))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

const feature = studies.find((e) => e.data.featured) ?? studies[0];
const rest = studies.filter((e) => e.id !== feature?.id).slice(0, 2);

const ladder = [
  { name: 'Automation Opportunity Audit', desc: "We map where your time and money are leaking, and hand you a costed plan. Fee credited against any project you go on to do.", amt: '£450', unit: 'from' },
  { name: 'Workflow Sprint', desc: '1–3 automations live in roughly two weeks.', amt: '£1,950', unit: 'from' },
  { name: 'System / Agent Build', desc: 'A proper custom system or AI agent, built to last.', amt: '£4,500', unit: 'from' },
  { name: 'AI Ops Partner', desc: 'We run it, watch it, and keep automating. Cancel anytime.', amt: '£495', unit: 'from', per: '/mo' },
];

const caps = [
  { name: 'Workflow automation', desc: 'The repetitive, multi-step admin between your tools, stitched into one clean flow.' },
  { name: 'Custom systems & portals', desc: 'Proper software built for how you actually work — not an off-the-shelf box you bend yourself around.' },
  { name: 'AI agents', desc: 'Software that reads, decides, drafts and acts — with a human keeping control of anything that matters.' },
  { name: 'AI Ops partnership', desc: 'We stay on, keep it running, and automate the next thing. Cancel anytime.' },
];
---

<BaseLayout
  title="AI & automation for UK small businesses"
  description="We make small businesses run like magic. It's not magic. It's very good engineering. AI and workflow automation from Automancer — audits from £450."
>
  <!-- ─────────────── Hero ─────────────── -->
  <section class="hero hatch">
    <div class="hero__glow" aria-hidden="true">
      <div class="hero__orb hero__orb--a" data-px="34"></div>
      <div class="hero__orb hero__orb--b" data-px="-22"></div>
    </div>
    <div class="hero__inner">
      <p class="eyebrow eyebrow--live hero__eyebrow">AI &amp; automation consultancy · Bradford → UK-wide</p>
      <h1 class="hero__headline">Your admin, automated into <span class="spectral-text">oblivion</span>.</h1>
      <p class="hero__reveal">We make small businesses run like magic.</p>
      <p class="hero__typed" aria-label="It's not magic. It's very good engineering.">
        <span class="prompt" aria-hidden="true">&gt;_ </span><span data-typed>It's not magic. It's very good engineering.</span><span class="hero__caret" aria-hidden="true"></span>
      </p>
      <p class="hero__body">
        Automancer builds the software and AI agents that do the boring, expensive, error-prone
        work your team shouldn't be doing by hand. Real systems, sensible prices, and a human who answers.
      </p>
      <div class="hero__ctas">
        <a href="/contact" class="btn"><span>Book an Automation Audit — from £450</span></a>
        <a href="/work" class="btn btn--ghost"><span>See the work</span><span class="btn__arrow">→</span></a>
      </div>
    </div>
  </section>

  <!-- ─────────────── Meta-story / proof ─────────────── -->
  <section class="section on-near">
    <div class="wrap">
      <div class="section-head reveal">
        <div class="section-head__top">
          <p class="eyebrow">The proof is the business you're looking at</p>
          <span class="section-head__log">// proof.log — live</span>
        </div>
        <h2>This whole company is run by AI. On purpose.</h2>
        <p>
          Most consultancies will tell you AI is the future. We just handed ours the keys — the
          finance ops, the project tracking, this website, the field notes. We don't demo automation
          in a slide deck. We live inside it. And a human — Waseem — makes every decision and takes
          every call. The agents do the work. The judgement stays human.
        </p>
      </div>

      <div class="proof-grid reveal-stagger">
        {[
          { n: '01', tag: 'finance', h: 'On autopilot', p: 'Agents run the invoicing, reconciliation and bookkeeping ops. Waseem approves.' },
          { n: '02', tag: 'delivery', h: 'Self-tracking', p: 'Every project lane is governed and monitored by agents, board-gated before anything touches a client.' },
          { n: '03', tag: 'content', h: 'This site & blog', p: "Written, built and maintained by the same agents we'd put to work in your business." },
          { n: '04', tag: 'control', h: 'One human in the loop', p: 'Every decision. Every call. No call centre, no "your ticket is important to us".' },
        ].map((c) => (
          <div class="proof-cell" data-spot>
            <span class="ghost-num" aria-hidden="true">{c.n}</span>
            <span class="proof-cell__n">{c.tag}</span>
            <h3>{c.h}</h3>
            <p>{c.p}</p>
          </div>
        ))}
      </div>

      <blockquote class="pullquote reveal" style="margin-top: clamp(3rem, 6vw, 5rem);">
        We're not selling you a tool we read about. We're selling you <span class="spectral-text">the thing we run our own company on</span>.
      </blockquote>
    </div>
  </section>

  <!-- ─────────────── What we do ─────────────── -->
  <section class="section on-paper">
    <div class="wrap">
      <div class="section-head">
        <div class="section-head__top">
          <p class="eyebrow">What we do</p>
          <span class="section-head__log">// capabilities: 4</span>
        </div>
        <h2>We automate the stuff that's eating your week.</h2>
        <p>
          If a person on your team spends hours copying data between systems, re-keying spreadsheets,
          chasing approvals, or answering the same question for the hundredth time — that's a job for
          a machine. We find those jobs, and we make them disappear.
        </p>
      </div>
      <ol class="cap-list reveal">
        {caps.map((c, i) => (
          <li class="cap-row">
            <span class="cap-row__n" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
            <span class="cap-row__name">{c.name}</span>
            <span class="cap-row__desc">{c.desc}</span>
          </li>
        ))}
      </ol>
      <p style="margin-top: var(--sp-10)">
        <a href="/services" class="arrow-link">Not sure what's automatable? That's literally the audit <span class="btn__arrow">→</span></a>
      </p>
    </div>
  </section>

  <!-- ─────────────── Price ladder teaser ─────────────── -->
  <section class="section on-dark hatch">
    <div class="wrap">
      <div class="section-head">
        <div class="section-head__top">
          <p class="eyebrow">Sensible prices, published</p>
          <span class="section-head__log">// no_funnel = true</span>
        </div>
        <h2>Not "let's get you on a call".</h2>
        <p>
          Enterprise automation firms quote enterprise numbers. We don't. Here's where things start —
          no funnel, no "it depends", no mystery.
        </p>
      </div>
      <div class="ladder reveal-stagger">
        {ladder.map((r) => (
          <div class="rung">
            <span class="rung__step"></span>
            <div class="rung__main">
              <h3 class="rung__name">{r.name}</h3>
              <p class="rung__desc">{r.desc}</p>
            </div>
            <div class="rung__price">
              <span class="from">{r.unit}</span>
              <span class="amt">{r.amt}</span>{r.per && <span class="unit">{r.per}</span>}
            </div>
          </div>
        ))}
      </div>
      <p style="margin-top: var(--sp-10)">
        <a href="/services" class="arrow-link">See what's included <span class="btn__arrow">→</span></a>
      </p>
    </div>
  </section>

  <!-- ─────────────── Selected work ─────────────── -->
  <section class="section on-near">
    <div class="wrap">
      <div class="section-head">
        <p class="eyebrow">Selected work</p>
        <h2>Real businesses. Real systems. Live in production.</h2>
      </div>
      <div class="case-grid">
        {feature && (
          <a href={`/work/${feature.id}`} class="case-card case-card--feature" data-spot>
            <span class="case-card__tag">{feature.data.sector}{feature.data.status ? ` · ${feature.data.status}` : ''}</span>
            <h3 class="case-card__title">{feature.data.title}</h3>
            <p class="case-card__blurb" set:html={feature.data.summary ?? feature.data.description} />
            <div class="case-card__foot">
              <span class="arrow-link">Read the case study <span class="btn__arrow">→</span></span>
            </div>
          </a>
        )}
        {rest.map((e) => (
          <a href={`/work/${e.id}`} class="case-card" data-spot>
            <span class="case-card__tag">{e.data.sector}</span>
            <h3 class="case-card__title">{e.data.title}</h3>
            <p class="case-card__blurb">{e.data.summary ?? e.data.description}</p>
            <div class="case-card__foot">
              <span class="arrow-link">Read <span class="btn__arrow">→</span></span>
            </div>
          </a>
        ))}
      </div>
      <p style="margin-top: var(--sp-10)">
        <a href="/work" class="arrow-link">See all our work <span class="btn__arrow">→</span></a>
      </p>
    </div>
  </section>

  <!-- ─────────────── Final CTA ─────────────── -->
  <section class="section on-dark cta hatch">
    <div class="cta__glow" aria-hidden="true"></div>
    <div class="wrap">
      <h2 class="cta__head">Tell us what's eating your week.</h2>
      <p class="cta__body">
        Fill in a short form. No calendar gauntlet, no chatbot, no sales sequence. Waseem reads it
        himself and emails you back — and we promise a meeting within one week of first contact.
      </p>
      <div class="cta__ctas">
        <a href="/contact" class="btn"><span>Start with an Audit — from £450</span></a>
        <a href="/contact" class="btn btn--ghost"><span>Just ask a question</span><span class="btn__arrow">→</span></a>
      </div>
      <p class="cta__reassure">
        Based in Bradford. Working with businesses in Leeds, Manchester and across the UK, remote-first.
      </p>
    </div>
  </section>
</BaseLayout>
