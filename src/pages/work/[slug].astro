---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const isProd = import.meta.env.PROD;
  // Drafts never build into the production site, so they can never appear in
  // the sitemap or be reached by URL; they stay available in dev for review.
  const studies = (await getCollection('case-studies'))
    .filter((e) => !(isProd && e.data.draft))
    .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
  return studies.map((entry, i) => ({
    params: { slug: entry.id },
    props: { entry, next: studies[(i + 1) % studies.length] },
  }));
}

const { entry, next } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;
---

<BaseLayout title={d.title} description={d.description}>
  <!-- Designed hero -->
  <article>
    <header class="page-hero hatch">
      <div class="page-hero__glow" aria-hidden="true"></div>
      <div class="page-hero__inner">
        <p class="eyebrow">
          {d.sector}
          {d.anonymised && <span class="sys" style="margin-left:.5rem">· anonymised</span>}
          {d.status && <span class="sys" style="margin-left:.5rem">· {d.status}</span>}
        </p>
        <h1 class="page-hero__title">{d.headline ?? d.title}</h1>
        {d.subhead && <p class="page-hero__sub">{d.subhead}</p>}
        {d.client && (
          <p class="form__micro" style="margin-top: var(--sp-6); max-width: 60ch;">
            <strong style="color:var(--ink)">Client:</strong> {d.client}
          </p>
        )}
      </div>
    </header>

    <!-- Stat band -->
    {d.stats.length > 0 && (
      <section class="section section--tight on-near">
        <div class="wrap">
          <div class="statband reveal-stagger">
            {d.stats.map((s) => (
              <div class="stat">
                <div class="stat__v">{s.v}</div>
                <div class="stat__l">{s.l}</div>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Long-form body -->
    <section class="section on-dark">
      <div class="wrap">
        <div class="prose case-prose">
          <Content />
        </div>
      </div>
    </section>

    <!-- Next + CTA -->
    <section class="section on-near">
      <div class="wrap">
        <div class="rule--spectral" style="margin-bottom: clamp(2.5rem,5vw,4rem)"></div>
        <div style="display:flex; flex-wrap:wrap; gap:var(--sp-8); justify-content:space-between; align-items:flex-end;">
          <div style="max-width: 40ch;">
            <p class="sys" style="margin-bottom: var(--sp-3)">Next case study</p>
            <a href={`/work/${next.id}`} class="case-card__title tlink" style="display:inline-block">{next.data.headline ?? next.data.title}</a>
          </div>
          <a href="/work" class="arrow-link">All work <span class="btn__arrow">→</span></a>
        </div>
      </div>
    </section>

    <section class="section on-dark cta hatch">
      <div class="cta__glow" aria-hidden="true"></div>
      <div class="wrap">
        <h2 class="cta__head">Got a job like this?</h2>
        <p class="cta__body">
          Start with an Audit and we'll show you exactly where automation would earn its keep — with
          real numbers and a plain plan. We promise a meeting within one week of first contact.
        </p>
        <div class="cta__ctas">
          <a href="/contact" class="btn"><span>Book an Audit — from £450</span></a>
          <a href="/work" class="btn btn--ghost"><span>See more work</span><span class="btn__arrow">→</span></a>
        </div>
      </div>
    </section>
  </article>
</BaseLayout>
