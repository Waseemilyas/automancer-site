---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const isProd = import.meta.env.PROD;
const studies = (await getCollection('case-studies'))
  .filter((e) => !(isProd && e.data.draft))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

const feature = studies.find((e) => e.data.featured) ?? studies[0];
const rest = studies.filter((e) => e.id !== feature?.id);
---

<BaseLayout
  title="Work"
  description="Real systems, live in production. Case studies from a care provider, a manufacturer, a diversity & inclusion consultancy and small firms — every fact taken from the actual work."
>
  <section class="page-hero hatch">
    <div class="page-hero__glow" aria-hidden="true"></div>
    <div class="page-hero__inner">
      <p class="eyebrow">Selected work</p>
      <h1 class="page-hero__title">Real businesses. Real systems. Live in production.</h1>
      <p class="page-hero__sub">
        Not concepts. Not pilots that never shipped. These are working systems we built for real UK
        businesses — a care provider, a manufacturer, a diversity &amp; inclusion consultancy, a handful
        of small firms who just needed a proper website. Here's what we did and what it changed.
      </p>
    </div>
  </section>

  <section class="section on-near">
    <div class="wrap">
      <div class="honesty reveal" style="margin-bottom: clamp(2.5rem, 5vw, 4rem);">
        <span class="honesty__mark">// honesty note</span>
        <p>
          Every case study here is anonymised at launch, while we get sign-off from each client to
          name them. Every fact, figure and outcome is real and taken from the actual work — we don't
          invent numbers.
        </p>
      </div>

      <div class="case-grid">
        {feature && (
          <a href={`/work/${feature.id}`} class="case-card case-card--feature">
            <span class="case-card__tag">
              {feature.data.sector}{feature.data.status ? ` · ${feature.data.status}` : ''}
            </span>
            <h2 class="case-card__title">{feature.data.title}</h2>
            <p class="case-card__blurb" set:html={feature.data.summary ?? feature.data.description} />
            <div class="case-card__foot">
              <span class="arrow-link">Read the case study <span class="btn__arrow">→</span></span>
              <span class="case-card__tag">{feature.data.tags.slice(0, 3).join(' · ')}</span>
            </div>
          </a>
        )}
        {rest.map((e) => (
          <a href={`/work/${e.id}`} class="case-card">
            <span class="case-card__tag">{e.data.sector}{e.data.status ? ` · ${e.data.status}` : ''}</span>
            <h2 class="case-card__title">{e.data.title}</h2>
            <p class="case-card__blurb">{e.data.summary ?? e.data.description}</p>
            <div class="case-card__foot">
              <span class="arrow-link">Read <span class="btn__arrow">→</span></span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section on-dark cta hatch">
    <div class="cta__glow" aria-hidden="true"></div>
    <div class="wrap">
      <h2 class="cta__head">Your business could be the next one on this page.</h2>
      <p class="cta__body">
        Start with an Audit and we'll show you where automation would pay for itself — with real
        numbers, not promises.
      </p>
      <div class="cta__ctas">
        <a href="/contact" class="btn"><span>Book an Audit — from £450</span></a>
        <a href="/services" class="btn btn--ghost"><span>See our services</span><span class="btn__arrow">→</span></a>
      </div>
    </div>
  </section>
</BaseLayout>
