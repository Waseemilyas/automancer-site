---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Website Terms" description="Website terms of use for Automancer Ltd.">
  <section class="page-hero hatch">
    <div class="page-hero__glow" aria-hidden="true"></div>
    <div class="page-hero__inner">
      <p class="eyebrow">Legal</p>
      <h1 class="page-hero__title">Website Terms</h1>
    </div>
  </section>

  <section class="section on-dark">
    <div class="wrap wrap--text prose" style="margin-inline:auto">
      <h2>Who we are</h2>
      <p>
        Automancer Ltd, a company registered in England and Wales.<br />
        Company number: 17060907.<br />
        62 Beckfield Road, Bingley, BD16 1QS.
      </p>

      <h2>Website use</h2>
      <p>
        You may browse and use this website for lawful purposes only. Do not misuse the site
        or attempt unauthorised access.
      </p>

      <h2>No professional advice</h2>
      <p>
        Website content is general information and not legal, tax, financial, or regulated
        professional advice.
      </p>

      <h2>Services and quotes</h2>
      <p>Service descriptions are indicative. Specific scope, timelines and fees are agreed in writing.</p>

      <h2>Intellectual property</h2>
      <p>
        Website content, branding and materials are owned by Automancer Ltd unless stated
        otherwise. Do not reuse without permission.
      </p>

      <h2>Liability</h2>
      <p>
        To the extent permitted by law, we are not liable for indirect losses from using this
        website. Nothing excludes liability where exclusion is unlawful.
      </p>

      <h2>Third-party links</h2>
      <p>External links are for convenience. We are not responsible for third-party content.</p>

      <h2>Changes</h2>
      <p>We may update these terms from time to time.</p>

      <h2>Governing law</h2>
      <p>These terms are governed by the laws of England and Wales.</p>
    </div>
  </section>
</BaseLayout>
